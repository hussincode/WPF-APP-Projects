<Page x:Class="Task_Management.Employeepage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Task_Management"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Employeepage" Loaded="window_Loaded">

    <Grid>
        <StackPanel>
            <Label Content="{Binding Name}"
                   Name="LABUsername"
                   />

            <TextBlock Text="Pending/In Progress"
                       Background="Wheat" Height="20" Width="141"
                       />

            <DataGrid x:Name="datagrid" SelectionChanged="datagrid_SelectionChanged" >
                
            </DataGrid>

            <StackPanel Orientation="Horizontal">
                <Label Content="Task"
                       FontSize="15"
                       FontWeight="Bold" Height="31"/>

                <TextBox Name="TXTTaskID" Height="28" Width="114"/>

                <Label Content="Status"
                       FontSize="15"
                       FontWeight="Bold" Height="31"/>

                <TextBox Name="TXTStatus" Height="28" Width="114"/>

                <Button Content="save" Margin="10,0,0,0"
                        Background="LawnGreen"
                        FontSize="15"
                        FontWeight="Bold"
                        BorderThickness="2" Click="Button_Click" />

            </StackPanel>

            <DataGrid x:Name="datagrid2" SelectionChanged="datagrid2_SelectionChanged" />

        </StackPanel>
    </Grid>
</Page>
