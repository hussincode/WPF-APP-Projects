<Page x:Class="Task_Management.LogInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Task_Management"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogInPage">

    <Grid>
        <Border Background="Wheat"
                Margin="226,50,226,50"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="9*"/>
                    <RowDefinition Height="19*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="74,10,74,10">
                    <Label Content="Username"
           FontSize="15"
           FontWeight="Bold" Height="31"/>
                    <TextBox  Name="TXTUsername" Height="28" Width="114"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="74,10,74,10" Grid.Row="1">
                    <Label Content="Password"
FontSize="15"
FontWeight="Bold" Height="31"/>
                    <PasswordBox  Name="TXTPass" Height="28" Width="114"/>
                </StackPanel>

                <Button Content="LOGIN" Margin="74,60,74,95" Grid.Row="2"
                        Background="LawnGreen"
                        FontSize="15"
                        FontWeight="Bold"
                        BorderThickness="2" Click="Button_Click"/>
            </Grid>


        </Border>
    </Grid>
</Page>
