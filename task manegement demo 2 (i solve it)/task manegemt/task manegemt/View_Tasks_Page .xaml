<Page x:Class="task_manegemt.View_Tasks_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:task_manegemt"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="View_Tasks_Page">

    <Grid Background="White">
        <StackPanel Orientation="Vertical">
            
            <Label Content="Progress/ in progress"/>
            <DataGrid Name="Datagridinprogress">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                <Setter Property="Background" Value="LightCyan"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <StackPanel Orientation="Horizontal">
                <Label Content="Task ID"/>
                <TextBox Name="TXTtaskID" Width="80"/>
                <Label Content="status"/>
                <ComboBox Name="combo" Width="84">
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="In Progress"/>
                    <ComboBoxItem Content="Completed"/>

                </ComboBox>
                

                <Button Content="save" Click="Button_Click"/>
            </StackPanel>
            <Label Content="complete"/>
            <DataGrid Name="Datagridcomplete">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                <Setter Property="Background" Value="LightCyan"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>
