<Page x:Class="task_manegemt.Log_In_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:task_manegemt"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Log_In_Page">

    <Grid Background="White">
        <Border Background="LightCoral"
                Margin="200,70"
                CornerRadius="20">
            <Border.Effect>

                <DropShadowEffect
                    Color="Black"
                    BlurRadius="80"
                    ShadowDepth="20"
                    Opacity="0.5">
                    
                </DropShadowEffect>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <Label Content="signup"
                      
                       FontSize="15"
                       FontWeight="Bold" Width="62"/>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Email:" Width="46"/>
                    <TextBox Name="TXTemail" Width="70"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal">
                    <Label Content="Password:" Width="46"/>
                    <PasswordBox Name="TXTpass" Width="70"/>
                </StackPanel>
                <Button Content="signup" Click="Button_Click"/>
            </StackPanel>

        </Border>
    </Grid>
</Page>
